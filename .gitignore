# Database files - NEVER commit SQLite databases
backend/prisma/dev.db
backend/prisma/dev.db-journal
backend/prisma/*.db
backend/prisma/*.db-shm
backend/prisma/*.db-wal

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript build info
*.tsbuildinfo

# Vite cache
.vite/
